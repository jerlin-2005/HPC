#include <pthread.h>
#include <stdio.h>
#include <stdlib.h>
#include <time.h>

#define SIZE 3

int A[SIZE][SIZE], B[SIZE][SIZE];
int SUM[SIZE][SIZE], PROD[SIZE][SIZE];

// Structure to hold the time result for each thread
typedef struct {
    double elapsed_time;
} ThreadResult;

void* matrix_add(void* arg) {
    struct timespec start, end;
    clock_gettime(CLOCK_MONOTONIC, &start);

    for (int i = 0; i < SIZE; i++) {
        for (int j = 0; j < SIZE; j++) {
            SUM[i][j] = A[i][j] + B[i][j];
        }
    }

    clock_gettime(CLOCK_MONOTONIC, &end);

    ThreadResult* res = malloc(sizeof(ThreadResult));
    res->elapsed_time = (end.tv_sec - start.tv_sec) + (end.tv_nsec - start.tv_nsec) / 1e9;
    return (void*)res;
}

void* matrix_mult(void* arg) {
    struct timespec start, end;
    clock_gettime(CLOCK_MONOTONIC, &start);

    for (int i = 0; i < SIZE; i++) {
        for (int j = 0; j < SIZE; j++) {
            PROD[i][j] = 0;
            for (int k = 0; k < SIZE; k++) {
                PROD[i][j] += A[i][k] * B[k][j];
            }
        }
    }
    clock_gettime(CLOCK_MONOTONIC, &end);

    ThreadResult* res = malloc(sizeof(ThreadResult));
    res->elapsed_time = (end.tv_sec - start.tv_sec) + (end.tv_nsec - start.tv_nsec) / 1e9;
    return (void*)res;
}

int main() {
    pthread_t thread1, thread2;
    ThreadResult *res_add, *res_mult;

    // 1. Get Input
    printf("Enter Matrix A (%dx%d):\n", SIZE, SIZE);
    for(int i=0; i<SIZE; i++) for(int j=0; j<SIZE; j++) scanf("%d", &A[i][j]);

    printf("Enter Matrix B (%dx%d):\n", SIZE, SIZE);
    for(int i=0; i<SIZE; i++) for(int j=0; j<SIZE; j++) scanf("%d", &B[i][j]);

    // 2. Create Threads
    pthread_create(&thread1, NULL, matrix_add, NULL);
    pthread_create(&thread2, NULL, matrix_mult, NULL);

    // 3. Join Threads and capture their return values (timing data)
    pthread_join(thread1, (void**)&res_add);
    pthread_join(thread2, (void**)&res_mult);

     printf("\n--- Matrix Addition Result ---\n");
    for (int i = 0; i < SIZE; i++) {
        for (int j = 0; j < SIZE; j++) printf("%d ", SUM[i][j]);
        printf("\n");
    }

    printf("\n--- Matrix Multiplication Result ---\n");
    for (int i = 0; i < SIZE; i++) {
        for (int j = 0; j < SIZE; j++) printf("%d ", PROD[i][j]);
        printf("\n");
    }
    printf("\n");
    printf("Addition Time:       %.8f seconds\n", res_add->elapsed_time);
    printf("Multiplication Time: %.8f seconds\n", res_mult->elapsed_time);

    // Free allocated memory
    free(res_add);
    free(res_mult);

    return 0;
}
