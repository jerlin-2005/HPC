#include <stdio.h>
#include <string.h>
#include <pthread.h>
#define BUFFER_SIZE 5
#define DICT_SIZE 20

// Dictionary - 20 words
const char* dictionary[] = {
    "hello", "world", "program", "computer", "thread",
    "process", "memory", "data", "file", "network",
    "socket", "server", "client", "buffer", "mutex",
    "variable", "function", "array", "pointer", "structure"
};

int dictSize = DICT_SIZE;

// Shared buffer
char buffer[BUFFER_SIZE][50];
int count = 0;
int head = 0;
int tail = 0;
int done = 0;

// Locks
pthread_mutex_t lock = PTHREAD_MUTEX_INITIALIZER;
pthread_cond_t cond = PTHREAD_COND_INITIALIZER;

int checkWord(char* word) {
    for (int i = 0; i < dictSize; i++) {
        if (strcmp(dictionary[i], word) == 0) return 1;
    }
    return 0;
}
void* master(void* arg) {
    char input[50];
    printf("=== SPELL CHECKER ===\n");
    printf("Enter words (type 'done' to finish):\n");
    printf("Available: hello, world, program, computer, thread, process, memory, data, file, network, socket, server, client, buffer, mutex, variable, function, array, pointer, structure\n\n");

    while (1) {
        printf("> ");
        fgets(input, 50, stdin);
        input[strlen(input)-1] = '\0';  // remove newline

        if (strcmp(input, "done") == 0) break;
        if (strlen(input) == 0) continue;

        // Add to buffer
        pthread_mutex_lock(&lock);
        while (count >= BUFFER_SIZE) {
            pthread_cond_wait(&cond, &lock);
        }

        strcpy(buffer[tail], input);
        tail = (tail + 1) % BUFFER_SIZE;
        count++;

        pthread_cond_signal(&cond);
        pthread_mutex_unlock(&lock);
    }

    // Signal done
    pthread_mutex_lock(&lock);
    done = 1;
    pthread_cond_broadcast(&cond);
    pthread_mutex_unlock(&lock);

    return NULL;
}

// ============================================================================
// WORKER THREAD - Check spelling
// ============================================================================
void* worker(void* arg) {
    int id = *(int*)arg;

    while (1) {
        char word[50];

        pthread_mutex_lock(&lock);

        // Wait for word
        while (count == 0 && !done) {
            pthread_cond_wait(&cond, &lock);
        }

        // Check if done
        if (count == 0 && done) {
            pthread_mutex_unlock(&lock);
            break;
        }

        // Get word from buffer
        strcpy(word, buffer[head]);
        head = (head + 1) % BUFFER_SIZE;
        count--;

        pthread_cond_signal(&cond);
        pthread_mutex_unlock(&lock);

        // Check spelling
        int result = checkWord(word);
        printf("[Worker-%d] %s -> %s\n", id, word, result ? "CORRECT" : "INCORRECT");
    }

    return NULL;
}
int main() {
    pthread_t masterThread, workerThread1, workerThread2;
    int id1 = 1, id2 = 2;

    // Create threads
    pthread_create(&masterThread, NULL, master, NULL);
    pthread_create(&workerThread1, NULL, worker, &id1);
    pthread_create(&workerThread2, NULL, worker, &id2);

    // Wait for all
    pthread_join(masterThread, NULL);
    pthread_join(workerThread1, NULL);
    pthread_join(workerThread2, NULL);

    printf("\n=== All Done! ===\n");

    return 0;
}
